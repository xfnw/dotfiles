# This is Git's per-user configuration file.
[include]
	path = .gitconfig-user
[init]
	defaultBranch = main
[sendemail]
	annotate = true
[alias]
	psuh = push
	ff = merge --ff-only
	br = !git log --oneline | head
	has = merge-base --is-ancestor
	quickserve = daemon --verbose --export-all --base-path=.git --reuseaddr --strict-paths .git/
	fetch-notes = !"git fetch ${1:-origin} $2refs/notes/*:refs/notes/* #"
	bundle-most = !git for-each-ref --include-root-refs --exclude REBASE_HEAD --exclude ORIG_HEAD --exclude PRE_ABSORB_HEAD --exclude refs/stash --exclude refs/remotes --format '%(refname)' | git bundle create
	cov = branch --edit-description
	churn = !"churn(){ git -c log.showSignature=false log -C -M --all --name-only --format= \"$@\" | sort | uniq -c | sort -h; };churn"
[commit]
	verbose = true
[pull]
	ff = only
[push]
	autoSetupRemote = true
[branch]
	sort = committerdate
[rerere]
	enabled = true
[format]
	coverFromDescription = auto
	notes = true
[notes]
	rewriteRef = refs/notes/commits
[mergetool "rustfmt"]
	cmd = rustfmt-mergetool \"$BASE\" \"$LOCAL\" \"$REMOTE\" \"$MERGED\"
	trustExitCode = true
[protocol "ssh"]
	allow = user
[am]
	threeWay = true
